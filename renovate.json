{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>nuxt/renovate-config-nuxt",
    ":prHourlyLimit4"
  ],
  "baseBranches": [
    "$default"
  ],
  "packageRules": [
    {
      "matchUpdateTypes": [
        "major"
      ],
      "enabled": false
    },
    {
      "groupName": "docs",
      "matchFileNames": [
        "docs/package.json"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "schedule": [
        "before 4am on the first day of the month"
      ]
    },
    {
      "groupName": "intlify",
      "matchFileNames": [
        "package.json"
      ],
      "matchPackageNames": [
        "vue-i18n",
        "@intlify/**"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ]
    },
    {
      "groupName": "vitest",
      "matchPackageNames": [
        "vitest",
        "/^@vitest//"
      ]
    },
    {
      "groupName": "rolldown",
      "groupSlug": "rolldown",
      "matchPackageNames": [
        "rolldown",
        "obuild",
        "tsdown",
        "oxc-parser",
        "oxc-walker",
        "oxc-transform",
        "@oxc-project/types"
      ]
    },
    {
      "groupName": "nitro",
      "groupSlug": "nitro",
      "matchPackageNames": [
        "nitro",
        "nitropack",
        "h3",
        "ofetch",
        "unstorage"
      ]
    }
  ]
}